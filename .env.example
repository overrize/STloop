# STLoop 大模型配置示例
# 复制为 .env 并填入实际值
# API Key 获取: https://platform.moonshot.cn/console/api-keys

# ========== OpenAI ==========
# OPENAI_API_KEY=sk-xxx

# ========== Kimi K2 (Moonshot，推荐) ==========
# 参考: https://platform.moonshot.cn/docs/guide/agent-support
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.moonshot.cn/v1
# 常用模型:
#   kimi-k2-0905-preview   - 256K 上下文，代码能力强
#   kimi-k2-turbo-preview  - 高速版，60-100 tokens/s
#   kimi-k2-thinking-turbo - 支持多步思考与工具调用
# OPENAI_MODEL=kimi-k2-0905-preview

# ========== 其他兼容 OpenAI 格式的 API ==========
# OPENAI_API_KEY=your-key
# OPENAI_API_BASE=https://your-api.com/v1
# OPENAI_MODEL=your-model
